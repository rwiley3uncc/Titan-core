# Example:
# TITAN_CALENDAR_SOURCES_JSON=[{"name":"School Calendar","type":"canvas","url":"https://example.com/school.ics","enabled":true},{"name":"Work Calendar","type":"outlook","url":"https://example.com/work.ics","enabled":true}]
TITAN_CALENDAR_SOURCES_JSON=[]
